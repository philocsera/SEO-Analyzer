# 이 파일을 복사해서 .env.local 을 만드세요:  cp .env.example .env.local
# 그다음 OPENAI_API_KEY 만 채우면 바로 동작합니다.

# ── 필수 ───────────────────────────────────────────────
# OpenAI (SEO AI 분석 + GEO LLM 리뷰, 기본 모델 gpt-5). 없으면 분석이 503으로 실패합니다.
# 발급: https://platform.openai.com/api-keys (결제수단 등록 + 크레딧 충전 필요)
OPENAI_API_KEY=

# ── 선택 ───────────────────────────────────────────────
# 아래는 전부 선택입니다. 안 쓸 키는 "주석(#)을 그대로 두거나 줄을 지우세요".
# ⚠️ 주석을 풀고 값을 비워두거나 예시 문자열을 그대로 두면 해당 API가
#    'API key not valid' 같은 에러 로그를 냅니다(분석 자체는 계속 진행됨).

# Core Web Vitals (Chrome UX Report)
# GOOGLE_PAGESPEED_API_KEY=

# 기업 공시 — 매출·직원 수 (금융감독원 DART)
# DART_API_KEY=

# 스마트스토어 분석 (네이버 검색 API)
# NAVER_CLIENT_ID=
# NAVER_CLIENT_SECRET=

# 키워드 검색량·경쟁도 (네이버 검색광고 API)
# NAVER_AD_CUSTOMER_ID=
# NAVER_AD_API_KEY=
# NAVER_AD_SECRET_KEY=

# ── 공개 배포 시 권장 (레이트리밋·전역 상한·결과 캐시) ──
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
